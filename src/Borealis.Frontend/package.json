{
  "name": "borealis-frontend",
  "packageManager": "yarn@4.9.4",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "lint:css": "stylelint (styles|static)/**/*.{scss,css}",
    "lint:js": "eslint scripts/**/*.{js,mjs}",
    "test": "vitest run",
    "test:chrome": "vitest run --browser.name=chrome --browser.headless",
    "test:safari": "vitest run --browser.name=safari",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --coverage",
    "test:coverage-report": "vitest run --coverage && npx --yes open-cli ./coverage/index.html",
    "test:ci": "vitest run --reporter=junit --coverage --outputFile=test-results/junit.xml"
  },
  "devDependencies": {
    "@codecov/vite-plugin": "^1.9.1",
    "@popperjs/core": "^2.11.8",
    "@stylistic/eslint-plugin-js": "^4.4.1",
    "@stylistic/stylelint-plugin": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.27",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "browserslist": "^4.26.2",
    "cssnano": "^7.1.3",
    "esbuild": "^0.27.4",
    "esbuild-plugin-browserslist": "^2.0.0",
    "eslint": "^9.35.0",
    "eslint-plugin-compat": "^6.0.2",
    "eslint-plugin-jsdoc": "^59.0.1",
    "eslint-plugin-testing-library": "^7.6.6",
    "eslint-plugin-vitest": "^0.5.4",
    "jquery": "^3.7.1",
    "jsdom": "^26.1.0",
    "jsdom-testing-mocks": "^1.15.2",
    "lit": "^3.3.1",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "postcss-scss": "^4.0.9",
    "pretender": "^3.4.7",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-visualizer": "^6.0.3",
    "sass": "^1.98.0",
    "stylelint": "^16.24.0",
    "stylelint-config-standard": "^39.0.0",
    "stylelint-config-standard-scss": "^16.0.0",
    "vite": "^7.1.11",
    "vite-plugin-mkcert": "^1.17.8",
    "vitest": "^3.2.4"
  }
}
